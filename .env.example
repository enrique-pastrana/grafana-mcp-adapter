# Grafana MCP adapter config. Copy to .env and fill in. NEVER commit .env.
#
# Auth uses a Grafana SERVICE ACCOUNT TOKEN (Bearer). Create a service account
# with a read-only role (Viewer) and generate a token (looks like `glsa_...`).
GRAFANA_ENABLED=true
GRAFANA_TOKEN=
# Base URL of your Grafana instance (no trailing /api). Examples:
#   https://myorg.grafana.net
#   https://grafana.mycompany.com
GRAFANA_BASE_URL=
# Optional overrides:
# GRAFANA_TIMEOUT_SECONDS=15
# GRAFANA_DEFAULT_LIMIT=20
